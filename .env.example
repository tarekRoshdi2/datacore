# ===========================================
#   DataCore - Environment Variables Example
#   انسخ هذا الملف إلى .env وعبّئ القيم
# ===========================================

# --- Frontend (Vite) ---
# من: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# رابط الـ Backend API
# في التطوير: اتركها فارغة (same origin)
# في production: اتركها فارغة إذا كان الـ backend والـ frontend على نفس السيرفر
VITE_API_URL=

# --- Backend (Node.js) ---
# منفذ السيرفر
PORT=3000

# بيئة التشغيل
NODE_ENV=development

# مفتاح Google Maps Places API
# من: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
